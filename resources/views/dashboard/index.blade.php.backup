            // Simulate data immediately
            simulateRealtimeData();

            // Update every second
            realtimeInterval = setInterval(simulateRealtimeData, 1000);
        }
    }

    // Update chart labels to sync with current time
    function updateChartLabels() {
        if (!realtimeChart) return;
        
        const currentHour = new Date().getHours();
        const labels = [];
        for (let i = -6; i <= 6; i++) {
            let hour = (currentHour + i + 24) % 24;
            labels.push(`${String(hour).padStart(2, '0')}:00`);
        }
        realtimeChart.data.labels = labels;
    }

    // Simulate Real-time Data
    function simulateRealtimeData() {
        // Generate random production data that rises and falls
        const currentHour = new Date().getHours();
        const newData = [];
        
        // Generate random values between 2-8 kWh for all hours (day and night)
        for (let i = -6; i <= 6; i++) {
            let hour = (currentHour + i + 24) % 24;
            
            // Random production between 2 and 8 kWh
            let baseProduction = 2 + Math.random() * 6;
            
            // Add some variation
            let variation = (Math.random() - 0.5) * 1.5;
            let value = Math.max(0.5, baseProduction + variation);
            newData.push(parseFloat(value.toFixed(2)));
        }
        
        if (realtimeChart) {
            realtimeChart.data.datasets[0].data = newData;
            realtimeChart.update('none');
        }
        
        // Calculate current power (middle of array = current hour)
        const currentPrice = newData[6] || 5;
        document.getElementById('currentPrice').textContent = `Current: ${currentPrice.toFixed(2)} kW`;
        
        // Also update today's production stat
        const totalToday = newData.reduce((a, b) => a + b, 0);
        document.getElementById('statToday').textContent = totalToday.toFixed(2);
        
        // Update last update time
        document.getElementById('lastUpdate').textContent = 'Last update: Just now';
    }

    // Update Real-time Chart
    function updateRealtimeChart(data) {
        if (realtimeChart && data.production) {
            const currentHour = new Date().getHours();
            
            // Get production data for the sliding window (current hour ± 6 hours)
            const newData = [];
            for (let i = -6; i <= 6; i++) {
                let hour = (currentHour + i + 24) % 24;
                newData.push(data.production[hour] || 0);
            }
            
            realtimeChart.data.datasets[0].data = newData;
            realtimeChart.update('none'); // Update without animation for smoothness
        }

        // Update current power display
        const currentHour = new Date().getHours();
        const currentPrice = data.production[currentHour] || 0;
        document.getElementById('currentPrice').textContent = `Current: ${currentPrice.toFixed(2)} kW`;
    }

    // Update Statistics
    function updateStats(data) {
        if (data.total_today !== undefined) {
            document.getElementById('statToday').textContent = data.total_today.toFixed(2);
        }
    }

    // Update Panel Readings Display
    function updatePanelReadings(panels) {
        const container = document.getElementById('panelReadings');

        if (panels.length === 0) {
            container.innerHTML = `
                <div class="text-center py-4">
                    <i class="bi bi-broadcast text-muted" style="font-size: 2rem;"></i>
                    <p class="mt-2 text-muted">No active panels</p>
                </div>
            `;
            return;
        }

        let html = '<div class="list-group list-group-flush">';
        panels.forEach(panel => {
            html += `
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <strong>${panel.serial_number}</strong>
                            <div class="small text-muted">${panel.last_reading || 'Just now'}</div>
                        </div>
                        <div class="text-end">
                            <span class="badge bg-success">${panel.power.toFixed(2)} W</span>
                            <div class="small text-muted">${panel.voltage.toFixed(1)}V / ${panel.amperage.toFixed(2)}A</div>
                        </div>
                    </div>
                </div>
            `;
        });
        html += '</div>';
        container.innerHTML = html;
    }

