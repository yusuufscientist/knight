    // Toggle Real-time Mode
    function toggleRealtime() {
        const btn = document.getElementById('toggleRealtime');
        const status = document.getElementById('realtimeStatus');

        if (isRealtimeActive) {
            // Stop real-time
            clearInterval(realtimeInterval);
            isRealtimeActive = false;
            btn.innerHTML = '<i class="bi bi-broadcast me-2"></i>Start Real-time';
            btn.classList.remove('btn-danger');
            btn.classList.add('btn-success');
            status.classList.add('d-none');
        } else {
            // Start real-time
            isRealtimeActive = true;
            btn.innerHTML = '<i class="bi bi-stop-circle me-2"></i>Stop Real-time';
            btn.classList.remove('btn-success');
            btn.classList.add('btn-danger');
            status.classList.remove('d-none');

            // Simulate data immediately
            simulateRealtimeData();

            // Update every second
            realtimeInterval = setInterval(simulateRealtimeData, 1000);
        }
    }

