@push('scripts')
<script>
    // Global variables
    let realtimeChart;
    let weeklyChart;
    let monthlyChart;
    let realtimeInterval;
    let isRealtimeActive = false;
    let weatherInterval;

    // Initialize charts when page loads
    document.addEventListener('DOMContentLoaded', function() {
        initWeeklyChart();
        initMonthlyChart();
        initRealtimeChart();
        
        // Load initial production data for real-time chart
        loadProductionData();

        // Toggle real-time button
        document.getElementById('toggleRealtime').addEventListener('click', toggleRealtime);
        
        // Start weather auto-refresh
        startWeatherUpdates();
    });

    // Load production data for real-time chart
    function loadProductionData() {
        fetch('/api/realtime/production', {
            headers: {
                'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').content,
                'Accept': 'application/json'
            },
            credentials: 'include'
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                updateRealtimeChart(data.data);
                updateStats(data.data);
            }
        })
        .catch(error => console.error('Error loading production data:', error));
    }

    // Weekly Production Chart
    function initWeeklyChart() {
        const ctx = document.getElementById('weeklyChart').getContext('2d');
        
        // Generate random price data for last 7 days
        const priceData = Array(7).fill(0).map(() => (0.08 + Math.random() * 0.12).toFixed(2));
        
        weeklyChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: {!! json_encode($productionChartData['labels']) !!},
                datasets: [{
                    label: 'Price ($/kWh)',
                    data: priceData,
                    borderColor: '#f59e0b',
                    backgroundColor: 'rgba(245, 158, 11, 0.1)',
                    borderWidth: 2,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: true, position: 'top' },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return '

    // Real-time Chart
    function initRealtimeChart() {
        const ctx = document.getElementById('realtimeChart').getContext('2d');
        const currentHour = new Date().getHours();
        
        // Generate labels based on current time (show last 12 hours + next 12 hours)
        const labels = [];
        for (let i = -6; i <= 6; i++) {
            let hour = (currentHour + i + 24) % 24;
            labels.push(`${String(hour).padStart(2, '0')}:00`);
        }
        
        // Initial price data
        const initialData = Array(13).fill(0).map(() => (0.10 + Math.random() * 0.15).toFixed(2));
        
        realtimeChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Price ($/kWh)',
                    data: initialData,
                    borderColor: '#10b981',
                    backgroundColor: 'rgba(16, 185, 129, 0.1)',
                    borderWidth: 2,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                animation: { duration: 0 },
                plugins: {
                    legend: { display: true, position: 'top' },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return '

    // Toggle Real-time Mode
    function toggleRealtime() {
        const btn = document.getElementById('toggleRealtime');
        const status = document.getElementById('realtimeStatus');

        if (isRealtimeActive) {
            // Stop real-time
            clearInterval(realtimeInterval);
            isRealtimeActive = false;
            btn.innerHTML = '<i class="bi bi-broadcast me-2"></i>Start Real-time';
            btn.classList.remove('btn-danger');
            btn.classList.add('btn-success');
            status.classList.add('d-none');
        } else {
            // Start real-time
            isRealtimeActive = true;
            btn.innerHTML = '<i class="bi bi-stop-circle me-2"></i>Stop Real-time';
            btn.classList.remove('btn-success');
            btn.classList.add('btn-danger');
            status.classList.remove('d-none');

            // Simulate data immediately
            simulateRealtimeData();

            // Update every second
            realtimeInterval = setInterval(simulateRealtimeData, 1000);
        }
    }

    // Update chart labels to sync with current time
    function updateChartLabels() {
        if (!realtimeChart) return;
        
        const currentHour = new Date().getHours();
        const labels = [];
        for (let i = -6; i <= 6; i++) {
            let hour = (currentHour + i + 24) % 24;
            labels.push(`${String(hour).padStart(2, '0')}:00`);
        }
        realtimeChart.data.labels = labels;
    }

    // Simulate Real-time Data
    function simulateRealtimeData() {
        // Generate random production data that rises and falls
        const currentHour = new Date().getHours();
        const newData = [];
        
        // Generate random values between 2-8 kWh for all hours (day and night)
        for (let i = -6; i <= 6; i++) {
            let hour = (currentHour + i + 24) % 24;
            
            // Random production between 2 and 8 kWh
            let baseProduction = 2 + Math.random() * 6;
            
            // Add some variation
            let variation = (Math.random() - 0.5) * 1.5;
            let value = Math.max(0.5, baseProduction + variation);
            newData.push(parseFloat(value.toFixed(2)));
        }
        
        if (realtimeChart) {
            realtimeChart.data.datasets[0].data = newData;
            realtimeChart.update('none');
        }
        
        // Calculate current power (middle of array = current hour)
        const currentPrice = newData[6] || 5;
        document.getElementById('currentPrice').textContent = `Current: ${currentPrice.toFixed(2)} kW`;
        
        // Also update today's production stat
        const totalToday = newData.reduce((a, b) => a + b, 0);
        document.getElementById('statToday').textContent = totalToday.toFixed(2);
        
        // Update last update time
        document.getElementById('lastUpdate').textContent = 'Last update: Just now';
    }

    // Update Real-time Chart
    function updateRealtimeChart(data) {
        if (realtimeChart && data.production) {
            const currentHour = new Date().getHours();
            
            // Get production data for the sliding window (current hour ± 6 hours)
            const newData = [];
            for (let i = -6; i <= 6; i++) {
                let hour = (currentHour + i + 24) % 24;
                newData.push(data.production[hour] || 0);
            }
            
            realtimeChart.data.datasets[0].data = newData;
            realtimeChart.update('none'); // Update without animation for smoothness
        }

        // Update current power display
        const currentHour = new Date().getHours();
        const currentPrice = data.production[currentHour] || 0;
        document.getElementById('currentPrice').textContent = `Current: ${currentPrice.toFixed(2)} kW`;
    }

    // Update Statistics
    function updateStats(data) {
        if (data.total_today !== undefined) {
            document.getElementById('statToday').textContent = data.total_today.toFixed(2);
        }
    }

    // Update Panel Readings Display
    function updatePanelReadings(panels) {
        const container = document.getElementById('panelReadings');

        if (panels.length === 0) {
            container.innerHTML = `
                <div class="text-center py-4">
                    <i class="bi bi-broadcast text-muted" style="font-size: 2rem;"></i>
                    <p class="mt-2 text-muted">No active panels</p>
                </div>
            `;
            return;
        }

        let html = '<div class="list-group list-group-flush">';
        panels.forEach(panel => {
            html += `
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <strong>${panel.serial_number}</strong>
                            <div class="small text-muted">${panel.last_reading || 'Just now'}</div>
                        </div>
                        <div class="text-end">
                            <span class="badge bg-success">${panel.power.toFixed(2)} W</span>
                            <div class="small text-muted">${panel.voltage.toFixed(1)}V / ${panel.amperage.toFixed(2)}A</div>
                        </div>
                    </div>
                </div>
            `;
        });
        html += '</div>';
        container.innerHTML = html;
    }

    // Weather auto-refresh
    function startWeatherUpdates() {
        fetchWeatherData();
