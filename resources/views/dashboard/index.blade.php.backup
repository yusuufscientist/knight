        fetch('/api/weather', {
            headers: {
                'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').content,
                'Accept': 'application/json'
            },
            credentials: 'include'
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                updateWeatherDisplay(data.data);
            }
        })
        .catch(error => console.error('Error fetching weather data:', error));
    }

    function updateWeatherDisplay(data) {
        // Update main weather card
        document.getElementById('weatherIcon').className = 'bi ' + data.condition_icon;
        document.querySelector('.weather-card-main .temperature').textContent = data.temperature + '°C';
        document.getElementById('weatherCondition').textContent = data.condition;
        document.querySelector('.weather-card-main .feels-like').textContent = 'Feels like ' + data.feels_like + '°C';
        
        // Update info cards
        document.getElementById('humidity').textContent = data.humidity + '%';
        document.getElementById('wind').textContent = data.wind_speed + ' km/h';
        document.getElementById('uvIndex').textContent = data.uv_index;
        document.getElementById('cloudCover').textContent = data.cloud_cover + '%';
        document.getElementById('solarIrradiance').textContent = data.solar_irradiance + ' W/m²';
        document.getElementById('productionImpact').textContent = data.production_impact.efficiency + '%';
        
        // Update impact bar
        const impactFill = document.querySelector('.impact-fill');
        if (impactFill) {
            impactFill.style.width = data.production_impact.efficiency + '%';
        }
    }
</script>
@endpush
